<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZapretUI.ViewModels"
             x:Class="ZapretUI.Views.LaunchWindow"
             x:DataType="vm:LaunchWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource MainColor_3}" />
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MainColor_4}" />
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextColor_0}" />
        </Style>
    </UserControl.Styles>

    <StackPanel HorizontalAlignment="Center"
                Margin="40 20 40 0">
        <TextBlock Text="{Binding SelectedStrategyName}"
                   HorizontalAlignment="Center"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource MainColor_4}"/>
        <Button Command="{Binding LaunchCommand}"
                Content="Запуск"
                Width="250"
                Height="100"
                Margin="0 40 0 0"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                FontSize="40"
                FontWeight="Bold"/>
    </StackPanel>
</UserControl>