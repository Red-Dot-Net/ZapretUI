<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZapretUI.ViewModels"
             x:Class="ZapretUI.Views.UpdateWindow"
             x:DataType="vm:UpdateWindowViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="{DynamicResource MainColor_3}" />
            <Setter Property="Foreground" Value="{DynamicResource TextColor_0}" />
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MainColor_3}" />
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextColor_0}" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource MainColor_3}"/>
            <Setter Property="Background" Value="{DynamicResource MainColor_3}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextColor_0}"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource MainColor_3}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MainColor_3}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextColor_0}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="40 0 40 0"
                    Spacing="10">
            <TextBlock Text="{Binding CurrentLoadedVersion}"/>
            <TextBlock Text="{Binding CurrentServerVersion}"/>
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding CheckForNewVersionCommand}"
                        HorizontalAlignment="Center"
                        Content="Проверить новую версию"
                        FontSize="20"
                        Padding="10"/>
                <Button Command="{Binding GetDownloadInfoCommand}"
                        Content="Показать ссылку на скачивание"
                        HorizontalAlignment="Center"
                        Margin="20 0 0 0"
                        FontSize="20"
                        Padding="10"/>
            </StackPanel>
            <TextBlock Text="{Binding DownloadUrlErrorMessage}"
                       IsVisible="{Binding IsDownloadErrorTextVisible}"/>
            <Border IsVisible="{Binding IsDownloadPanelVisible}"
                    CornerRadius="5"
                    BorderThickness="3"
                    BorderBrush="{DynamicResource MainColor_3}"
                    Padding="2">
                <StackPanel>
                    <HyperlinkButton Content="Ссылка на скачивание архива"
                                     NavigateUri="{Binding DownloadUrl}"
                                     HorizontalAlignment="Center"
                                     Margin="0 5 0 0"
                                     FontSize="20"
                                     Foreground="{DynamicResource TextColor_0}"/>
                    <TextBlock Text="{Binding DownloadUrl}"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource MainColor_3}"/>
                </StackPanel>
            </Border>
            <Border IsVisible="{Binding IsDownloadPanelVisible}"
                    Height="150"
                    Background="{DynamicResource MainColor_3}"
                    Padding="40"
                    Margin="0 20 0 0"
                    BorderThickness="3"
                    CornerRadius="10"
                    BorderBrush="{DynamicResource MainColor_3}"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragOver="OnDragOver"
                    DragDrop.Drop="OnDrop">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="DragAndDropInfoMessageBlock"
                               Text="Перетащите архив в это окно"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource TextColor_0}"/>
                    <TextBlock x:Name="DragAndDropFileNameBlock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsVisible="False"
                               FontSize="18"
                               Foreground="{DynamicResource TextColor_0}"/>
                </StackPanel>
            </Border>
            <Border IsVisible="{Binding IsInfoTextVisible}"
                    BorderThickness="3"
                    BorderBrush="{DynamicResource MainColor_3}"
                    CornerRadius="3">
                <TextBlock Text="{Binding InfoText}"
                           Margin="5"
                           MaxWidth="300"
                           TextWrapping="Wrap"
                           Foreground="red"/>
            </Border>
            <Button IsVisible="{Binding IsUpdateButtonVisible}"
                    Command="{Binding UpdateCommand}"
                    Content="Обновить"
                    HorizontalAlignment="Center"
                    Margin="0 20 0 0"
                    Padding="15"
                    FontSize="25"/>
            <Button Command="{Binding CheckIpListCommand}"
                    Content="Проверить актуальность IP адресов"
                    HorizontalAlignment="Center"
                    Margin="0 30 0 0"
                    Padding="10"
                    FontSize="16"/>
            <Border IsVisible="{Binding IsUpdateListInfoVisible}"
                    BorderThickness="3"
                    BorderBrush="{DynamicResource MainColor_3}"
                    Background="{DynamicResource MainColor_3}"
                    CornerRadius="3"
                    Padding="10">
                <TextBlock Text="{Binding UpdateListInfo}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextColor_0}"/>
            </Border>
            <Button Command="{Binding UpdateListCommand}"
                    IsVisible="{Binding IsUpdateListButtonVisible}"
                    Content="Обновить список IP адресов"
                    HorizontalAlignment="Center"
                    Margin="0 5 0 10"
                    Padding="10"
                    FontSize="16"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>